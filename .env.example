# Required. Clients must send: Authorization: Bearer <value>.
# Use a long random value, for example: openssl rand -hex 32
DOGOK_PROXY_API_KEY=change-me-to-a-long-random-token
DOGOK_PROXY_REQUIRE_API_KEY=true

# Keep false for external exposure. Temporarily set true only on a trusted
# network if Swagger/OpenAPI inspection is needed, then restart the service.
DOGOK_PROXY_ENABLE_DOCS=false

# Public server settings inside the container. docker-compose binds it to
# 192.168.0.16:31835 on the dogok host.
APP_HOST=0.0.0.0
APP_PORT=8000

# Queue / worker settings.
GPT_QUEUE_DB_PATH=/app/data/jobs.sqlite3
GPT_QUEUE_CONCURRENCY=2
GPT_MAX_QUEUE_SIZE=1000
GPT_JOB_TIMEOUT_SECONDS=900
GPT_JOB_MAX_ATTEMPTS=3
GPT_JOB_RETENTION_HOURS=24
GPT_DEFAULT_REASONING_EFFORT=low
GPT_AUTH_REFRESH_MARGIN_SECONDS=604800
GPT_AUTH_REFRESH_LOOP_INTERVAL_SECONDS=3600

# openai-oauth subprocess settings.
GPT_OAUTH_COMMAND=openai-oauth
GPT_OAUTH_FILE=/auth/auth.json
GPT_OAUTH_HOST=127.0.0.1
GPT_OAUTH_PORT=10531
GPT_OAUTH_STARTUP_TIMEOUT_SECONDS=20
GPT_UPSTREAM_BASE_URL=http://127.0.0.1:10531/v1
